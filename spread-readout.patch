# Spread readout — dashboard addition
#
# Adds a self-contained page at  http://localhost:<port>/spread  showing:
#   - each open paper/shadow trade with its current + max spread (points)
#   - a tally of stop-loss exits and how many were spread-induced
# No edits to the existing dashboard/index.html. Two parts: engine + server.
# Depends on dynamic-spread-SL.diff (which writes state/spread_trace.jsonl).
# ============================================================================


# ---------------------------------------------------------------------------
# 1) engine.py — persist a running max spread per open trade.
#    (a) add a module-level dict near the other module state at the top:
# ---------------------------------------------------------------------------
_open_spread: Dict[int, Dict[str, Any]] = {}


#    (b) inside manage_open_trades(), within the `if tr["mode"] in ("paper",
#        "shadow"):` block, right AFTER the line `max_spr_pts = w.get(...)`,
#        record the running max:
            rec = _open_spread.setdefault(tr["id"],
                                          {"symbol": tr["symbol"], "max_spread_pts": 0})
            if (max_spr_pts or 0) > rec["max_spread_pts"]:
                rec["max_spread_pts"] = max_spr_pts
            rec["cur_spread_pts"] = price_info.get("spread")


#    (c) at the END of manage_open_trades() (next to the px_window reset),
#        prune closed trades and dump to disk:
    open_ids = {t["id"] for t in open_trs}
    for _tid in list(_open_spread):
        if _tid not in open_ids:
            _open_spread.pop(_tid, None)
    try:
        import json as _json, os as _os
        _os.makedirs("state", exist_ok=True)
        with open("state/open_spread.json", "w") as _f:
            _json.dump({str(k): v for k, v in _open_spread.items()}, _f)
    except Exception as _e:
        print("open_spread dump error:", _e)


# ---------------------------------------------------------------------------
# 2) server.py — add the JSON endpoint and the self-contained page.
#    Paste both routes alongside the other @app.route handlers.
# ---------------------------------------------------------------------------
@app.route("/api/spread")
def api_spread():
    import json as _json
    feed = engine.get_feed()
    prices = feed.get("prices", {})
    try:
        with open(os.path.join(BASE, "state", "open_spread.json")) as f:
            osp = _json.load(f)
    except Exception:
        osp = {}

    opens = []
    for tr in storage.open_trades():
        if tr["mode"] not in ("paper", "shadow"):
            continue
        pr = prices.get(tr["symbol"], {})
        rec = osp.get(str(tr["id"]), {})
        opens.append({
            "id": tr["id"], "symbol": tr["symbol"], "side": tr["side"],
            "mode": tr["mode"], "entry": tr["entry"], "sl": tr["sl"],
            "cur_spread_pts": rec.get("cur_spread_pts", pr.get("spread")),
            "max_spread_pts": rec.get("max_spread_pts"),
        })

    total = induced = 0
    by_sym, recent = {}, []
    try:
        with open(os.path.join(BASE, "state", "spread_trace.jsonl")) as f:
            lines = f.readlines()
        for ln in lines:
            try:
                r = _json.loads(ln)
            except Exception:
                continue
            total += 1
            if r.get("spread_induced"):
                induced += 1
                by_sym[r["symbol"]] = by_sym.get(r["symbol"], 0) + 1
        recent = [_json.loads(x) for x in lines[-8:] if x.strip()]
    except Exception:
        pass

    return jsonify({"open": opens,
                    "stops": {"total": total, "spread_induced": induced,
                              "by_symbol": by_sym, "recent": recent}})


